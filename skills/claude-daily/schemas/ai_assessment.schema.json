{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["member_id", "date_range", "submitted_at", "manager_md", "personal_md", "meta", "backbones"],
  "additionalProperties": false,
  "properties": {
    "member_id":    {"type": "string", "pattern": "^[a-z][a-z0-9._-]{2,40}$"},
    "date_range":   {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}(~[0-9]{4}-[0-9]{2}-[0-9]{2})?$"},
    "submitted_at": {"type": "string", "minLength": 26},
    "manager_md":   {"type": "string", "minLength": 1},
    "personal_md":  {"type": "string", "minLength": 1},
    "meta":         {"type": "object"},
    "backbones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["session_short", "events"],
        "properties": {
          "session_short": {"type": "string", "minLength": 1},
          "session_id":    {"type": "string"},
          "project":       {"type": "string"},
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["i", "type", "text"],
              "properties": {
                "i":    {"type": "integer", "minimum": 0},
                "type": {"type": "string"},
                "text": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}
